{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).min.css",
      "headers": [
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=31536000, stale-while-revalidate=86400"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).min.js",
      "headers": [
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=31536000, stale-while-revalidate=86400"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).min.json",
      "headers": [
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
